@{ ViewData["Title"] = "Recuperar senha"; }
<section class="page-card auth-card" data-page="forgot-password-page"><p class="eyebrow">Recuperação de acesso</p><h1>Esqueci minha senha</h1><p class="text-muted">Enviaremos instruções se o e-mail estiver habilitado no Valora Pulse, sem revelar existência da conta.</p><form class="needs-validation valora-form" novalidate><label class="form-label">E-mail</label><input class="form-control form-control-lg" type="email" name="email" autocomplete="email" required><button class="btn btn-primary btn-lg mt-4" type="submit">Enviar instruções</button></form><div class="alert alert-danger d-none mt-3 error-state" role="alert"></div><div class="alert alert-success d-none mt-3 success-state"></div></section>
@section Scripts { <script src="/js/pages/forgot-password-page.js"></script> }
