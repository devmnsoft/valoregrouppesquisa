@{ ViewData["Title"] = "Status do ambiente"; }
<section class="page-card" data-page="environment-status-page"><div class="d-flex justify-content-between align-items-start gap-3 flex-wrap"><div><p class="eyebrow">Admin SaaS</p><h1>Status do ambiente</h1><p class="text-muted">Monitore API, banco, migração, logs e versão.</p></div><button class="btn btn-primary" data-primary-action>Atualizar</button></div><div class="loading-state alert alert-info mt-3">Carregando dados da API...</div><div class="alert alert-warning d-none mt-3 plan-limit-alert" role="alert"></div><div class="alert alert-danger d-none mt-3 error-state" role="alert"></div><div class="empty-state alert alert-secondary d-none mt-3">Sem registros para os filtros atuais.</div><div class="table-toolbar mt-3"><div class="filter-panel row g-2"><div class="col-md-4"><input class="form-control" data-filter-text aria-label="Filtro" placeholder="Filtrar registros"></div></div></div><div class="table-responsive mt-3"><table class="table table-sm align-middle"><thead><tr><th>Recurso</th><th>Status</th><th>Detalhes</th><th>Ações</th></tr></thead><tbody data-table-body></tbody></table></div><div class="pagination small text-muted" data-pagination>1 página</div><div class="confirm-modal d-none" data-confirm-modal></div><div class="copy-link-button d-none" data-copy-helper></div></section>
