@{ ViewData["Title"] = "Redefinir senha"; }
<section class="page-card auth-card" data-page="reset-password-page"><p class="eyebrow">Nova credencial</p><h1>Redefinir senha</h1><p class="text-muted">Informe o código recebido e cadastre uma nova senha forte.</p><form class="needs-validation valora-form" novalidate><label class="form-label">Código de recuperação</label><input class="form-control" name="token" autocomplete="one-time-code" required><label class="form-label mt-3">Nova senha</label><input class="form-control" type="password" name="password" autocomplete="new-password" minlength="8" required><label class="form-label mt-3">Confirmar nova senha</label><input class="form-control" type="password" name="confirmPassword" autocomplete="new-password" minlength="8" required><button class="btn btn-primary btn-lg mt-4" type="submit">Redefinir senha</button></form><div class="alert alert-danger d-none mt-3 error-state" role="alert"></div><div class="alert alert-success d-none mt-3 success-state"></div></section>
@section Scripts { <script src="/js/pages/reset-password-page.js"></script> }
