@{ ViewData["Title"] = "Migração"; }
<section class="page-card official-module" data-page="migration-page">
  <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
    <div><p class="eyebrow">Valora.Web oficial</p><h1>Migração</h1><p class="text-muted">Status de migração, divergências e cutover bloqueado.</p></div>
    <button class="btn btn-primary" data-refresh>Atualizar</button>
  </div>
  <div class="row g-3 mt-2" data-summary-cards><div class="col-md-4"><div class="metric-card"><span>Status</span><strong data-card="status">Aguardando API</strong></div></div><div class="col-md-4"><div class="metric-card"><span>Firebase preservado</span><strong data-card="firebase-preservado">Aguardando API</strong></div></div><div class="col-md-4"><div class="metric-card"><span>Cutover bloqueado</span><strong data-card="cutover-bloqueado">Aguardando API</strong></div></div></div>
  <div class="alert alert-warning d-none mt-3" data-gap-controlled="true" data-gap-card>Recurso em ativação controlada. Consulte ASPNET_WEB_API_GAPS.md.</div>
  <div class="alert alert-danger d-none mt-3" role="alert" data-error></div>
  <div class="table-responsive mt-3"><table class="table table-sm align-middle"><thead><tr><th>Nome</th><th>Status</th><th>Detalhes</th><th>Ação</th></tr></thead><tbody data-items></tbody></table></div>
</section>
@section Scripts { <script src="/js/pages/migration-page.js"></script> }
