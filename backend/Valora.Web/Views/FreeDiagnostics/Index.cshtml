@{ ViewData["Title"] = "Diagnósticos gratuitos"; }
<section class="page-card official-module" data-page="free-diagnostics-page" data-required-permission="canViewResponses" data-allowed-roles="admin_valora,consultor_valora,empresa_admin,gestor_pesquisa,analista_resultados">
  <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap"><div><p class="eyebrow">Operação LGPD</p><h1>Diagnósticos gratuitos</h1><p class="text-muted">Acompanhe respostas, e-mails, certificados, falhas, reenvios e WhatsApp comercial sem expor tokens, hashes, senhas ou corpo completo de e-mail.</p></div><button class="btn btn-primary" data-refresh>Atualizar</button></div>
  <div class="alert alert-danger d-none mt-3" data-error role="alert"></div>
  <form class="row g-2 mt-2" data-filters><div class="col-md-2"><label class="form-label">Data inicial</label><input class="form-control" type="date" name="startDate"></div><div class="col-md-2"><label class="form-label">Data final</label><input class="form-control" type="date" name="endDate"></div><div class="col-md-2"><label class="form-label">Nome</label><input class="form-control" name="name"></div><div class="col-md-2"><label class="form-label">E-mail</label><input class="form-control" name="email"></div><div class="col-md-2"><label class="form-label">Status e-mail</label><select class="form-select" name="emailStatus"><option value="">Todos</option><option>pending</option><option>processing</option><option>sent</option><option>failed</option><option>reviewed</option></select></div><div class="col-md-2"><label class="form-label">Certificado</label><select class="form-select" name="certificateStatus"><option value="">Todos</option><option>metadata-ready</option><option>generated</option><option>not-generated</option></select></div><div class="col-md-2"><label class="form-label">Maturidade</label><input class="form-control" name="maturityLevel"></div><div class="col-md-2 align-self-end"><button class="btn btn-outline-primary w-100" type="submit">Filtrar</button></div></form>
  <div class="row g-3 mt-2" data-summary></div>
  <div class="visually-hidden">Reenviar Falar com especialista Valora</div><h2 class="h5 mt-4">Últimas respostas</h2><div class="table-responsive"><table class="table table-sm align-middle"><thead><tr><th>Participante</th><th>E-mail</th><th>Maturidade</th><th>Comunicação</th><th>Certificado</th><th>Falha sanitizada</th><th>Ações</th></tr></thead><tbody data-items></tbody></table></div>
  <h2 class="h5 mt-4">Últimos envios e falhas recentes</h2><div data-failures class="small text-muted">Carregando...</div>
</section>
@section Scripts { <script src="/js/api/free-diagnostics-api.js"></script><script src="/js/pages/free-diagnostics-page.js"></script> }
