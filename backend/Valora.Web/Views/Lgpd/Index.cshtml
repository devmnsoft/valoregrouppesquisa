@{ ViewData["Title"] = "Lgpd"; }
<div class="container-fluid py-3" data-module="Lgpd">
  <div class="d-flex justify-content-between align-items-center mb-3"><h1 class="h3">Lgpd</h1><span class="badge text-bg-info">Backend oficial</span></div>
  <div class="card shadow-sm"><div class="card-body"><p class="text-muted">Tela MVC/Razor oficial com Bootstrap 5 e AJAX seguro. Dados sensíveis como senha, hash, token e segredo SMTP não são exibidos.</p><div class="alert alert-secondary empty-state">Use as ações disponíveis para carregar dados reais da API oficial.</div><button class="btn btn-primary" data-load-operational>Carregar</button><pre class="mt-3 d-none" data-result></pre></div></div>
</div>
@section Scripts { <script src="/js/api/operational-api.js"></script> }
