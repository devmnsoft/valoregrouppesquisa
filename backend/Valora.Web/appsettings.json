{
  "Api": {
    "BaseUrl": "https://api.valoragroup.mnsoft.com.br",
    "TimeoutMs": 20000
  },
  "WebApp": {
    "Name": "Valora Pulse",
    "Version": "1.0.0-web",
    "Environment": "Production",
    "PublicUrl": "https://valoragroup.mnsoft.com.br",
    "EnableDebugLogs": false
  },
  "Firebase": {
    "Plan": "blaze",
    "EnableCloudFunctions": true,
    "PublicSubmissionProvider": "auto",
    "ResultProvider": "auto",
    "EmailTransport": "auto",
    "FallbackToCloudFunctions": true
  },
  "FreeSurvey": {
    "NeverExpireOfficialFreeSurvey": true
  },
  "CommunicationGateway": {
    "BaseUrl": "https://api.valoragroup.mnsoft.com.br",
    "SendResultOnSurveyCompleted": true,
    "FallbackToCloudFunctions": true
  }
}
