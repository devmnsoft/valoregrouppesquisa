# Homologação local descartável — não use estes valores em produção.
VALORA_POSTGRES_DB=valora_hml
VALORA_POSTGRES_USER=valora_hml
VALORA_POSTGRES_PASSWORD=change-me-local-only
VALORA_POSTGRES_HOST=localhost
VALORA_POSTGRES_PORT=5432
VALORA_BACKUP_DIR=./backups/postgresql
VALORA_ENVIRONMENT=Homologation
VALORA_MIGRATION_MAX_FILE_MB=50
VALORA_MIGRATION_BATCH_SIZE=500
VALORA_MIGRATION_TIMEOUT_SECONDS=300
VALORA_TEST_POSTGRES_CONNECTION=Host=localhost;Port=5432;Database=valora_hml;Username=valora_hml;Password=change-me-local-only
