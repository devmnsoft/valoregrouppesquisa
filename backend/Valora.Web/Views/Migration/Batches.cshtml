@{
    ViewData["Title"] = "Migração controlada";
    var batchId = ViewData["BatchId"]?.ToString() ?? "";
}
<div class="container-fluid py-4 migration-page" data-batch-id="@batchId">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div><h1 class="h3">Migração controlada legado → PostgreSQL</h1><p class="text-muted">Dry-run obrigatório, conciliação, apply explícito, rollback por batch e payload sensível mascarado.</p></div>
        <a class="btn btn-outline-primary" href="/Migration/Batches">Ver batches</a>
    </div>
    <div class="row g-3 mb-3">
        <div class="col-md-3"><div class="card"><div class="card-body"><span class="text-muted">Status</span><h2 id="migrationStatus">Aguardando</h2></div></div></div>
        <div class="col-md-3"><div class="card"><div class="card-body"><span class="text-muted">Válidos</span><h2 id="validRecords">0</h2></div></div></div>
        <div class="col-md-3"><div class="card"><div class="card-body"><span class="text-muted">Conflitos</span><h2 id="conflictRecords">0</h2></div></div></div>
        <div class="col-md-3"><div class="card"><div class="card-body"><span class="text-muted">Sensíveis</span><h2>Mascarados</h2></div></div></div>
    </div>
    <div class="alert alert-info">Nenhum JSON bruto, senha, hash, token, segredo, connection string ou stack trace é exibido nesta tela.</div>
    <div class="btn-group mb-3">
        <a class="btn btn-secondary" href="/Migration/Upload">Upload</a><a class="btn btn-secondary" href="/Migration/DryRun/@batchId">Dry-run</a><a class="btn btn-secondary" href="/Migration/Conflicts/@batchId">Conflitos</a><a class="btn btn-secondary" href="/Migration/Reconciliation/@batchId">Conciliação</a><a class="btn btn-secondary" href="/Migration/Rollback/@batchId">Rollback</a><a class="btn btn-secondary" href="/Migration/CutoverReadiness/@batchId">Cutover readiness</a>
    </div>
    <div class="card"><div class="card-header">Divergências</div><div class="card-body"><div class="row g-2 mb-2"><div class="col"><input class="form-control" placeholder="Filtrar entidade" /></div><div class="col"><input class="form-control" placeholder="Filtrar status/severidade" /></div></div><table class="table table-sm"><thead><tr><th>Entidade</th><th>Status</th><th>Severidade</th><th>Mensagem</th></tr></thead><tbody id="migrationRows"><tr><td colspan="4" class="text-muted">Estado vazio: execute um dry-run para carregar divergências mascaradas.</td></tr></tbody></table></div></div>
    <div class="mt-3"><button class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#applyModal">Aplicar com confirmação explícita</button> <button class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#rollbackModal">Rollback com confirmação explícita</button></div>
</div>
<div class="modal" id="applyModal"><div class="modal-dialog"><div class="modal-content"><div class="modal-header"><h5>Confirmar apply</h5></div><div class="modal-body">Digite a confirmação operacional no backend. A ação exige dry-run prévio e admin_valora.</div></div></div></div>
<div class="modal" id="rollbackModal"><div class="modal-dialog"><div class="modal-content"><div class="modal-header"><h5>Confirmar rollback</h5></div><div class="modal-body">Rollback por batch; casos inseguros ficam como revisão manual.</div></div></div></div>
<script src="/js/migration.js"></script>
