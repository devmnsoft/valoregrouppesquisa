@{ ViewData["Title"] = "Saúde operacional"; }
<section class="page-card" data-page="operations-page">
  <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
    <div><p class="eyebrow">Operação</p><h1>Painel de saúde operacional</h1><p class="text-muted">Monitoramento sem segredos de status da API, status do banco, status do SMTP, status da fila de e-mail, pesquisa gratuita, status do certificado público, CSP, Firebase legado e Valora.Web.</p></div>
    <span class="badge text-bg-success">admin_valora · consultor_valora · empresa_admin</span>
  </div>
  <div class="alert alert-danger d-none mt-3" data-operations-error></div>
  <div class="row g-3 mt-2" data-operations-cards></div>
  <div class="card mt-3"><div class="card-body"><h2>Ações operacionais</h2><div class="d-flex flex-wrap gap-2">
    <button class="btn btn-primary" data-op-action="health">Testar health</button>
    <button class="btn btn-outline-primary" data-op-action="email">Testar SMTP config</button>
    <button class="btn btn-outline-primary" data-op-action="free-survey">Testar link pesquisa gratuita</button>
    <button class="btn btn-outline-primary" data-op-action="certificates">Testar validação de certificado</button>
    <button class="btn btn-warning" data-op-action="process-queue">Processar fila de e-mail</button>
    <a class="btn btn-outline-secondary" href="/Audit">Abrir relatório de erros</a>
  </div><pre class="mt-3 bg-light p-3" data-operations-output>Pronto para executar.</pre></div></div>
</section>
@section Scripts { <script src="/js/api/operations-api.js"></script><script src="/js/pages/operations-page.js"></script> }
