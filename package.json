{
  "name": "valora-pulse-security-tests",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "check": "node --check app.js && node --check firebase-repository.js && node --check functions/index.js",
    "security:check": "node scripts/security-check.js",
    "build:prod": "node scripts/build-production.js",
    "test:rules": "npx firebase emulators:exec --only firestore \"npx mocha tests/rules/**/*.test.js --timeout 20000\"",
    "test:functions": "npx firebase emulators:exec --only firestore,functions \"npx mocha tests/functions/**/*.test.js --timeout 30000\"",
    "test:security": "npm run test:rules && npm run test:functions",
    "emulators:start": "npx firebase emulators:start --only auth,firestore,functions",
    "check:no-dist": "node scripts/check-no-dist-committed.js",
    "postbuild:security": "node scripts/postbuild-security-check.js",
    "serve:local": "python server.py",
    "test:visual": "playwright test tests/visual",
    "test:visual:headed": "playwright test tests/visual --headed",
    "test:visual:update": "playwright test tests/visual --update-snapshots",
    "export:local": "node scripts/export-local-state.js",
    "import:firebase:dry": "node scripts/import-local-export-to-firebase.js --dry-run",
    "validate:prd:data": "node scripts/validate-prd-data.js",
    "release:prd:data": "node scripts/release-prd-with-data.js",
    "publish:iis:dry": "node scripts/publish-iis-prd.js --dry-run --mode firebase",
    "publish:iis": "node scripts/publish-iis-prd.js --apply --mode firebase",
    "publish:iis:local": "node scripts/publish-iis-prd.js --apply --mode local",
    "package:iis": "node scripts/publish-iis-prd.js --package-only --mode firebase",
    "prod:dry": "node scripts/go-production.js --dry-run",
    "prod:go": "node scripts/go-production.js --apply",
    "prod:go:data": "node scripts/go-production.js --apply --with-data --open-browser",
    "prod:health": "node scripts/healthcheck-prd.js --url https://valoragroup.mnsoft.com.br --project gestordepesquisa",
    "validate:data-contracts": "node scripts/validate-data-contracts.js",
    "validate:render-resilience": "node scripts/validate-render-resilience.js",
    "audit:data-shapes": "node scripts/audit-data-shapes.js",
    "test:home-featured": "npx mocha tests/home-featured-survey.spec.js",
    "backend:build": "dotnet build backend/Valora.sln",
    "backend:test": "dotnet test backend/Valora.sln",
    "postgres:up": "docker compose -f docker-compose.postgres.yml up -d",
    "migration:validate": "node migration/validate-migration.js",
    "architecture:check": "node scripts/validate-architecture-transition.js",
    "journey:provider": "node scripts/validate-public-journey-provider.js",
    "migration:compare": "node migration/compare-firebase-postgres.js",
    "backend:health": "node scripts/validate-api-backend.js",
    "postgres:mvp": "node scripts/validate-vertical-postgres-mvp.js",
    "hybrid:check": "node scripts/validate-hybrid-provider.js",
    "api:provider": "node scripts/validate-api-provider.js",
    "architecture:warnings": "node scripts/validate-architecture-warnings.js",
    "api:e2e": "node scripts/validate-end-to-end-api-flow.js",
    "cutover:ready": "node scripts/validate-cutover-readiness.js",
    "migration:dry-run-real": "node scripts/validate-real-migration-dry-run.js",
    "postgres:schema": "node scripts/validate-single-postgres-schema.js",
    "backend:implementation": "node scripts/validate-backend-implementation.js",
    "backend:clean": "node scripts/validate-backend-clean-architecture.js",
    "runtime:docker-windows": "node scripts/validate-docker-windows-runtime.js",
    "frontend:bootstrap": "node scripts/validate-bootstrap-frontend.js",
    "api:routes": "node scripts/validate-public-api-routes.js",
    "api:public-real": "node scripts/validate-public-api-real-flow.js",
    "api:result-token": "node scripts/validate-result-token-security.js",
    "api:transactional-submit": "node scripts/validate-transactional-public-submit.js"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.4",
    "@playwright/test": "^1.45.0",
    "firebase": "^10.14.1",
    "firebase-admin": "^12.7.0",
    "firebase-tools": "^13.29.2",
    "mocha": "^10.8.2"
  }
}
